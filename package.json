{
  "name": "compliancezk",
  "version": "1.0.0",
  "description": "ComplianceZK: First ZK-verified regulatory attestation protocol with Auth0 identity decoupling and on-chain proof enforcement for autonomous agents",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "circuit:compile": "circom circuits/compliance_attestation.circom --r1cs --wasm --sym --c",
    "circuit:setup": "snarkjs groth16 setup circuits/compliance_attestation.r1cs circuits/compliance_attestation_final.zkey circuits/final_p1.key",
    "circuit:export": "snarkjs zkey export verificationkey circuits/compliance_attestation_final.zkey circuits/verification_key.json",
    "proof:generate": "node scripts/generateComplianceProof.js",
    "proof:verify": "node scripts/verifyComplianceProof.js",
    "contract:compile": "npx hardhat compile",
    "contract:deploy": "npx hardhat run scripts/deployComplianceVerifier.js --network localhost",
    "agent:verify": "node scripts/agentComplianceCheck.js",
    "protocol:init": "node scripts/initComplianceProtocol.js",
    "test:all": "npx hardhat test && node tests/circuit.test.js"
  },
  "dependencies": {
    "@auth0/auth0-node": "^1.0.0",
    "circomlib": "^2.0.5",
    "ethers": "^6.13.4",
    "snarkjs": "^0.7.5",
    "blake2b": "^2.1.3",
    "merkletreejs": "^0.3.11"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "@types/node": "^22.10.5",
    "hardhat": "^2.22.10",
    "typescript": "^5.7.2",
    "circom": "^2.0.5"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "zero-knowledge",
    "zk-snark",
    "compliance",
    "kyc",
    "aml",
    "auth0",
    "agent",
    "regulatory",
    "privacy-preserving",
    "decentralized-identity"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./circuit": {
      "types": "./dist/circuit/index.d.ts",
      "import": "./dist/circuit/index.js"
    },
    "./protocol": {
      "types": "./dist/protocol/index.d.ts",
      "import": "./dist/protocol/index.js"
    },
    "./verifier": {
      "types": "./dist/verifier/index.d.ts",
      "import": "./dist/verifier/index.js"
    }
  },
  "files": [
    "dist/",
    "circuits/",
    "contracts/",
    "scripts/",
    "tests/"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/compliancezk/compliancezk.git"
  },
  "license": "MIT",
  "compliancezk": {
    "protocolVersion": "1.0.0",
    "circuitName": "compliance_attestation",
    "proofSystem": "groth16",
    "verificationContract": "ComplianceVerifier",
    "auth0Domain": "${AUTH0_DOMAIN}",
    "auth0ClientId": "${AUTH0_CLIENT_ID}",
    "auth0ClientSecret": "${AUTH0_CLIENT_SECRET}",
    "zkPublicKey": "circuits/verification_key.json",
    "complianceCriteria": {
      "ageMinimum": 18,
      "sanctionCheck": true,
      "jurisdictionWhitelist": ["US", "EU", "UK", "CA"],
      "amlThreshold": 10000
    }
  }
}